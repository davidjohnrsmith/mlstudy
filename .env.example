# Environment variables template
# Copy to .env and fill in values (never commit .env)

# Data vendor API keys
# POLYGON_API_KEY=
# ALPACA_API_KEY=
# ALPACA_SECRET_KEY=

# Broker credentials
# BROKER_API_KEY=
# BROKER_API_SECRET=

# Database connections
# DATABASE_URL=

# Experiment tracking
# WANDB_API_KEY=
# MLFLOW_TRACKING_URI=
